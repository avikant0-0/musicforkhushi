# Copy this file to ".env" and fill in your values.

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# YouTube Data API v3 key — required for searching songs / recommendations.
# Get one free at https://console.cloud.google.com/ :
#   1. Create a project   2. Enable "YouTube Data API v3"   3. Create an API key.
YOUTUBE_API_KEY=

# Sanity — the permanent song library. Audio is extracted from YouTube, uploaded
# here as file assets, and streamed from Sanity's CDN.
# Create a free project at https://www.sanity.io/ , then a token with WRITE
# access (Manage > API > Tokens, role "Editor").
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_TOKEN=
# Optional — Sanity API version (defaults to 2024-01-01)
# SANITY_API_VERSION=2024-01-01

# Optional — path to the yt-dlp binary if it isn't on PATH.
# YTDLP_PATH=yt-dlp
