# Copy this file to ".env" and fill in your values.

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# YouTube Data API v3 key — required for searching songs and getting recommendations.
# Get one free at: https://console.cloud.google.com/
#   1. Create a project
#   2. Enable "YouTube Data API v3"
#   3. Create an API key under "Credentials"
# Without this key, you can still paste YouTube links/IDs and listen together,
# but search and recommendations will be disabled.
YOUTUBE_API_KEY=
