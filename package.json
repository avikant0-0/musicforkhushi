{
  "name": "musicforkhushi",
  "version": "2.0.0",
  "description": "Listen to YouTube music together, in sync — audio extracted and streamed from Sanity.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "client": "npm --prefix client run dev",
    "client:build": "npm --prefix client install && npm --prefix client run build",
    "build": "npm run client:build",
    "studio": "npm --prefix studio run dev",
    "studio:deploy": "npm --prefix studio run deploy",
    "songs": "node server/list-songs.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "youtube",
    "music",
    "listen-together",
    "sync",
    "sanity",
    "socket.io"
  ],
  "license": "MIT",
  "dependencies": {
    "@sanity/client": "^7.23.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  }
}
